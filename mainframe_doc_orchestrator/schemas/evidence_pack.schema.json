{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvidencePack",
  "type": "object",
  "required": ["request_id", "question", "supporting_chunks", "graph_paths", "supporting_data", "confidence"],
  "properties": {
    "request_id": {"type": "string"},
    "question": {"type": "string"},
    "section_name": {"type": "string"},
    "system_id": {"type": "string"},
    "supporting_chunks": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Ordered list of chunk_ids (vector-retrieved + gap-filled)."
    },
    "chunk_contents": {
      "type": "object",
      "description": "Full source text and location keyed by chunk_id.",
      "additionalProperties": {
        "type": "object",
        "required": ["chunk_id", "asset_id", "asset_type", "chunk_kind", "chunk_name", "text", "source_file", "line_start", "line_end"],
        "properties": {
          "chunk_id": {"type": "string"},
          "asset_id": {"type": "string"},
          "asset_type": {"type": "string"},
          "chunk_kind": {"type": "string"},
          "chunk_name": {"type": "string"},
          "text": {"type": "string"},
          "source_file": {"type": "string"},
          "line_start": {"type": "integer"},
          "line_end": {"type": "integer"}
        },
        "additionalProperties": false
      }
    },
    "graph_paths": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path_id", "path_label", "nodes", "edges"],
        "properties": {
          "path_id": {"type": "string"},
          "path_label": {"type": "string"},
          "nodes": {"type": "array"},
          "edges": {"type": "array"},
          "supporting_chunks": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "supporting_data": {
      "type": "object",
      "description": "Structured asset inventory keyed by type: jobs, procs, programs, copybooks, parms."
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_type", "ref", "relevance"],
        "properties": {
          "item_type": {"type": "string", "enum": ["chunk", "graph_path", "supporting_data"]},
          "ref": {"type": "string"},
          "relevance": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
