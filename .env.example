# =================================================================
# Mainframe Document Orchestrator — environment configuration
#
# Copy this file to .env and fill in the values for the providers
# you intend to use.
#
# Only secrets and environment-specific values belong here.
# Stable defaults (timeouts, top_k, temperature, app name, etc.)
# are configured directly in settings.py and do not need to be
# overridden here unless you specifically need a different value
# for a given environment.
# =================================================================

# ---------------------------------------------------------------
# DATABASE  (required — credentials, never commit to source control)
# ---------------------------------------------------------------
POSTGRES_DSN=postgresql://<user>:<password>@<host>:5432/mainframe_doc_orchestrator

# ---------------------------------------------------------------
# LLM PROVIDER
# Set LLM_PROVIDER to one of: stub | openai | bedrock
# Then fill in ONLY the section that matches your choice.
# ---------------------------------------------------------------
LLM_PROVIDER=stub

# -- openai (secret + environment-specific endpoint/model) --
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...          # secret — required for openai provider
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=4096  # gpt-4o / gpt-4o-mini: up to 16384

# -- bedrock (environment-specific model + region) --
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_REGION=us-east-1
BEDROCK_MAX_OUTPUT_TOKENS=4096  # Claude 3.5 Sonnet: up to 8192
# AWS credentials resolved via standard chain (env vars, ~/.aws/credentials, IAM role)

# ---------------------------------------------------------------
# RETRIEVAL PROVIDER
# Set RETRIEVAL_PROVIDER to one of: http | stub
# Then fill in ONLY the section that matches your choice.
# ---------------------------------------------------------------
RETRIEVAL_PROVIDER=http

# -- http --
RETRIEVAL_ENDPOINT=http://localhost:8001/retrieve
RETRIEVAL_EVIDENCE_ENDPOINT_TEMPLATE=http://localhost:8001/evidence-packs/{request_id}

# -- stub (environment-specific path to a local evidence-pack JSON file) --
RETRIEVAL_STUB_PATH=mainframe_retrieval_bundle/sample_data/evidence_packs/billing-001.json
